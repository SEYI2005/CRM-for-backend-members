 Server
PORT=5000
NODE_ENV=development

# Database
# Local MongoDB example:  mongodb://127.0.0.1:27017/clientflow
# Atlas example:          mongodb+srv://<username>:<password>@<cluster>.mongodb.net/clientflow
MONGO_URI=

# Frontend (used for CORS so the httpOnly cookie is accepted cross-origin)
